import "../../0-common/asy/utils.ah" as utils;

size(55mm);

draw(box((-1.2,-1.2), (1.2,1.2)), invisible);

path p = (-0.7, -0.5) --
         ( 0.5, -0.4) --
         ( 0.2,  0.2) --
         ( 0.8,  0.6) --
         ( 0.0,  0.7) --
         (-0.5,  0.3) --
         (-0.6, -0.4) -- cycle;

filldraw(p, pens[0]+opacity(0.3), pens[0] + linewidth(1pt) );
label("$R$", (0.1, 0.4));

draw(circle((0,0), 1.1));

